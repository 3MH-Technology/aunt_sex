{
  "name": "aunt-sex",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "npm run build:worker && npm run build:web",
    "build:web": "npm run build --workspace=web",
    "build:worker": "npm run build --workspace=worker",
    "start": "turbo start",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "turbo": "^1.13.3"
  }
}
